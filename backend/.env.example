# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno de la aplicación.
#
# Este archivo centraliza la configuración utilizada por Symfony y los
# servicios externos. Los valores sensibles deben sustituirse por credenciales
# reales únicamente en los entornos correspondientes.
# ─────────────────────────────────────────────────────────────────────────────

# Entorno de ejecución de la aplicación.
APP_ENV=dev

# Clave utilizada internamente por Symfony para tareas de seguridad.
APP_SECRET=change-me

# Conexión principal a la base de datos PostgreSQL.
# Usuario de runtime recomendado: bame_app con privilegios mínimos.
# Para migraciones usa un usuario aparte de mantenimiento/administracion.
DATABASE_URL="postgresql://bame_app:CHANGE_ME@host:5432/postgres?serverVersion=16&charset=utf8"

# Orígenes permitidos para las peticiones CORS.
CORS_ALLOW_ORIGIN="^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$|^https://.*\.vercel\.app$"

# Duración de los tokens de autenticación en días.
BAME_TOKEN_TTL_DAYS=30

# Credenciales de Stripe para el entorno de pruebas.
# Usa sk_test_ en dev/test y sk_live_ exclusivamente en produccion.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Origenes exactos autorizados para los retornos de Stripe Checkout.
# Desarrollo: se permiten localhost y HTTP.
CHECKOUT_ALLOWED_ORIGINS="http://localhost:4200,http://127.0.0.1:4200"
# Produccion (usar en el entorno prod, sin comodines):
# CHECKOUT_ALLOWED_ORIGINS="https://asaderobame.com"
